# Idea Scout — Pipeline Configuration
# Copy this file to config/local.sh and fill in your values.

# ── Paths (optional) ──
EMAIL_CONFIG_PATH=""             # Optional private env file for CHATANYWHERE_API_KEY / EMAIL_TO / SMTP_USER
GMAIL_TOKEN_PATH=""              # Gmail OAuth token JSON used by local launchd delivery
GMAIL_CREDENTIALS_PATH=""        # Gmail OAuth desktop/web client JSON, if token lacks client_id/client_secret

# ── Email (optional overrides) ──
IDEA_SCOUT_EMAIL_TO=""           # All-source recipient override for local Gmail delivery
CEPM_EMAIL_TO=""                 # CE/PM recipients (overrides EMAIL_TO from email-config.sh)
CNKI_EMAIL_TO=""                 # CNKI recipients (overrides EMAIL_TO from email-config.sh)
GMAIL_FROM=""                    # Defaults to SMTP_USER from EMAIL_CONFIG_PATH
GMAIL_SENDER_NAME=""             # Defaults to the digest source label
DIGEST_OUTPUT_DIR=""             # Defaults to logs/digests

# ── App (optional) ──
DASHBOARD_URL=""                 # Defaults to http://127.0.0.1:5174; opens after scans with new papers

# ── Optional private email-config.sh variables ──
# The launchd pipeline exports HTML/manifest, sends mail through the local
# Gmail API OAuth token, then runs pipeline/email/mark_sent.py.
#
# EMAIL_TO=recipient1@example.com,recipient2@example.com
# CHATANYWHERE_API_KEY=your-chatanywhere-api-key
