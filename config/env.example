# Idea Scout — Pipeline Configuration
# Copy this file to config/local.sh and fill in your values.

# ── Paths (required) ──
EMAIL_CONFIG_PATH=""             # Path to email-config.sh (SMTP/API credentials)

# ── Email (optional overrides) ──
SENDER_NAME="Journal Scout"     # Email sender display name
CEPM_EMAIL_TO=""                 # CE/PM recipients (overrides EMAIL_TO from email-config.sh)
CNKI_EMAIL_TO=""                 # CNKI recipients (overrides EMAIL_TO from email-config.sh)

# ── App (optional) ──
APP_URL=""                       # Idea Scout App URL (opens in browser after scan)

# ── Gmail API (optional, for API-based sending) ──
GMAIL_TOKEN_PATH=""              # Path to gmail_token.json (leave empty for SMTP-only)

# ── Required in email-config.sh ──
# Create a separate email-config.sh with these variables:
#
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_TO=recipient1@example.com,recipient2@example.com
# CHATANYWHERE_API_KEY=your-chatanywhere-api-key
